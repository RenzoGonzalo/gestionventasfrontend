# Si defines VITE_API_BASE_URL, Axios usará esa URL.
# Si lo dejas vacío, se usará el mismo origen (recomendado con proxy de Vite).
VITE_API_BASE_URL=

# Target del proxy de Vite (vite.config.ts). Solo aplica en dev.
VITE_API_PROXY_TARGET=http://localhost:4000

# Google (Store Admin login)
VITE_GOOGLE_CLIENT_ID=
